# ===== Variables de Entorno — Core Mobile Banco de los Andes =====
# Copiar a .env y ajustar para cada entorno:
#     copy .env.example .env
#
# En PRODUCCIÓN (Render/Koyeb), NO uses .env.
# Las variables se configuran desde el panel de la plataforma.
# ================================================================

# ── Obligatorias ────────────────────────────────────────────────
# DATABASE_URL es OBLIGATORIA en todos los entornos.
# Sin ella el backend no arranca.
# Formato: postgresql+psycopg2://user:password@host:5432/db?sslmode=require
DATABASE_URL=postgresql+psycopg2://user:password@host:5432/db?sslmode=require

# SECRET_KEY es OBLIGATORIA. Cámbiala en producción por una clave segura.
# Generar: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=genera_una_clave_segura_con_el_comando_anterior

# ── Opcionales (con valores por defecto) ────────────────────────
ENV=development
PORT=8010
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
FIREBASE_WEB_API_KEY=

# ── CORS (separado por comas) ───────────────────────────────────
# En desarrollo: http://localhost:5173,http://localhost:8010
# En producción: https://tu-portal.vercel.app,https://backend-core-los-andes.onrender.com
CORS_ORIGINS=http://localhost:5173,http://localhost:8010
