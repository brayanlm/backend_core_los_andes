@startuml类图
' ============================================================
' Diagrama de Clases — bd_core_mobile
' ============================================================
left header
  <b>Banco de los Andes</b>
  Core Mobile — Modelo de Datos
end header

class cr_cliente {
  + id: TEXT (PK)
  + numero_documento: TEXT (UNIQUE)
  + nombres: TEXT
  + apellidos: TEXT
  + telefono: TEXT
  + direccion: TEXT
  + email: TEXT
  + tipo_negocio: TEXT
  + nombre_negocio: TEXT
  + antiguedad_negocio_meses: INT
  + calificacion_sbs: TEXT
  + lat: REAL
  + lng: REAL
  + es_prospecto: INT
}

class cr_credito {
  + id: TEXT (PK)
  + solicitud_id: TEXT (FK)
  + cliente_id: TEXT (FK)
  + asesor_id: TEXT (FK)
  + monto: REAL
  + plazo_meses: INT
  + tasa: REAL
  + estado: TEXT
  + dias_mora: INT
  + cuotas_total: INT
  + cuotas_pagadas: INT
}

class cr_solicitud_credito {
  + id: TEXT (PK)
  + numero_expediente: TEXT (UNIQUE)
  + asesor_id: TEXT (FK)
  + cliente_id: TEXT (FK)
  + monto: REAL
  + plazo: INT
  + estado: TEXT
}

class cr_cronograma_pago {
  + id: TEXT (PK)
  + credito_id: TEXT (FK)
  + nro_cuota: INT
  + fecha_vencimiento: TEXT
  + monto_cuota: REAL
  + monto_capital: REAL
  + monto_interes: REAL
  + saldo: REAL
  + estado_cuota: TEXT
}

class cr_cuenta_ahorro {
  + id: TEXT (PK)
  + cliente_id: TEXT (FK)
  + cod_cuenta_ahorro: TEXT
  + saldo_capital: REAL
  + tea: REAL
}

class cr_movimiento {
  + id: TEXT (PK)
  + cliente_id: TEXT (FK)
  + tipo: TEXT
  + monto: REAL
  + fecha_operacion: TEXT
}

class cr_tarjeta {
  + id: TEXT (PK)
  + cliente_id: TEXT (FK)
  + linea_credito: REAL
  + saldo_utilizado: REAL
}

class cr_sync_outbox {
  + id: TEXT (PK)
  + entidad: TEXT
  + operacion: TEXT
  + datos: TEXT (JSON)
  + estado: TEXT
}

class cr_sync_log {
  + id: TEXT (PK)
  + tipo: TEXT
  + entidad: TEXT
  + registros: INT
